language ESSENCE' 1.0

given fin1: int
given fin2: int
given fin3: int
given fin4: int
given fin5: int
given fin6: int
given dataset_ExplicitBoundedR6_Length: int(fin1)
given dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy:
        matrix indexed by [int(1..fin1), int(1..fin2)] of int(fin3..fin4 + 1)
given dataset_ExplicitBoundedR6_Values_2: matrix indexed by [int(1..fin1)] of int(fin5..fin6)
letting n be
        max([dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q47, q48]
                 | q47 : int(1..fin1), q48 : int(1..fin2), q47 <= fin1,
                   dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q47, q48] != fin4 + 1])
letting nbObservations be fin1
find omitList_ExplicitBounded_Length: int(nbObservations)
find omitList_ExplicitBounded_Values: matrix indexed by [int(1..nbObservations)] of bool
find rel1_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
find survivor1_ExplicitBoundedR2_Length: int(nbObservations)
find survivor1_ExplicitBoundedR2_Values_Occurrence: matrix indexed by [int(1..nbObservations), int(1..n)] of bool
find rel2_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
find survivor2_ExplicitBoundedR3_Length: int(nbObservations)
find survivor2_ExplicitBoundedR3_Values_Explicit: matrix indexed by [int(1..nbObservations), int(1)] of int(1..n)
find score: int(0)
find path1_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
find path2_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
such that
    and([and([and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, q33] ->
                   or([dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q35] = q33
                           | q35 : int(1..fin2),
                             dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q35] != fin4 + 1])
                       | q33 : int(1..n)]),
              row <= nbObservations, row <= fin1;
                  int(1..3)])
         /\
         (omitList_ExplicitBounded_Values[row] /\
          !and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, dataset_ExplicitBoundedR6_Values_2[row]],
                row <= fin1, row <= nbObservations;
                    int(1..3)])
          /\ row <= nbObservations
          \/
          !omitList_ExplicitBounded_Values[row] /\ row <= nbObservations /\
          and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, dataset_ExplicitBoundedR6_Values_2[row]], row <= fin1,
               row <= nbObservations;
                   int(1..3)]))
         /\
         and([survivor1_ExplicitBoundedR2_Values_Occurrence
                  [row, dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q37]]
              /\ row <= nbObservations
              <->
              and([!rel1_RelationAsMatrix
                        [dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q36],
                         dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q37]]
                       | q36 : int(1..fin2),
                         dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q36] != fin4 + 1,
                         row <= fin1])
                  | q37 : int(1..fin2),
                    dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q37] != fin4 + 1, row <= fin1])
             | row : int(1..nbObservations)]),
    and([and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, survivor2_ExplicitBoundedR3_Values_Explicit[row, 1]],
              row <= nbObservations, row <= nbObservations;
                  int(1..3)])
         /\
         (omitList_ExplicitBounded_Values[row] /\
          !and([survivor2_ExplicitBoundedR3_Values_Explicit[row, 1] = dataset_ExplicitBoundedR6_Values_2[row],
                row <= fin1, row <= nbObservations;
                    int(1..3)])
          /\ row <= nbObservations
          \/
          !omitList_ExplicitBounded_Values[row] /\ row <= nbObservations /\
          and([survivor2_ExplicitBoundedR3_Values_Explicit[row, 1] = dataset_ExplicitBoundedR6_Values_2[row],
               row <= fin1, row <= nbObservations;
                   int(1..3)]))
         /\
         and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, q2] ->
              (survivor2_ExplicitBoundedR3_Values_Explicit[row, 1] = q2 /\ row <= nbObservations <->
               and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, y] -> !rel2_RelationAsMatrix[y, q2]
                        | y : int(1..n), row <= nbObservations]))
                  | q2 : int(1..n), row <= nbObservations])
             | row : int(1..nbObservations)]),
    0 = sum([toInt(omitList_ExplicitBounded_Values[row]) | row : int(1..nbObservations)]),
    and([row <= nbObservations | row : int(1..nbObservations)]),
    and([rel1_RelationAsMatrix[q30_1, q30_2] -> path1_RelationAsMatrix[q30_1, q30_2]
             | q30_1 : int(1..n), q30_2 : int(1..n), q30_1 != q30_2]),
    and([path1_RelationAsMatrix[q4, y] /\ path1_RelationAsMatrix[y, z] -> path1_RelationAsMatrix[q4, z]
             | q4 : int(1..n), y : int(1..n), z : int(1..n)]),
    and([!path1_RelationAsMatrix[q5, q5] | q5 : int(1..n)]),
    and([rel2_RelationAsMatrix[q32_1, q32_2] -> path2_RelationAsMatrix[q32_1, q32_2]
             | q32_1 : int(1..n), q32_2 : int(1..n), q32_1 != q32_2]),
    and([path2_RelationAsMatrix[q7, y] /\ path2_RelationAsMatrix[y, z] -> path2_RelationAsMatrix[q7, z]
             | q7 : int(1..n), y : int(1..n), z : int(1..n)]),
    and([!path2_RelationAsMatrix[q8, q8] | q8 : int(1..n)]),
    1 <= sum([sum([toInt(rel1_RelationAsMatrix[q15, q16]) | q16 : int(1..n)]) | q15 : int(1..n)]),
    and([!rel1_RelationAsMatrix[q12, q12] | q12 : int(1..n)]),
    and([true | q17 : int(1..nbObservations)]),
    1 <= sum([sum([toInt(rel2_RelationAsMatrix[q23, q24]) | q24 : int(1..n)]) | q23 : int(1..n)]),
    and([!rel2_RelationAsMatrix[q20, q20] | q20 : int(1..n)])

