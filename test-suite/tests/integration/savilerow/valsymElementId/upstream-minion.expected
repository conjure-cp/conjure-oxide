MINION 3
# CSETopLevel_number = 0
# CSETopLevel_eliminated_expressions = 0
# CSETopLevel_total_size = 0
# CSE_active_number = 0
# CSE_active_eliminated_expressions = 0
# CSE_active_total_size = 0
**VARIABLES**
DISCRETE x_00002 #
{1..2}
DISCRETE aux0 #ElementOne([1, 2], x_00002)
{1..2}
DISCRETE aux1 #ElementOne([1, 3], x_00002)
{1..3}
**CONSTRAINTS**
w-inintervalset(aux1, [1,1,3,3])
**VARIABLES**
DISCRETE aux2 #ElementOne([1, 4], x_00002)
{1..4}
**CONSTRAINTS**
w-inintervalset(aux2, [1,1,4,4])
**VARIABLES**
DISCRETE aux3 #ElementOne([1, 5], x_00002)
{1..5}
**CONSTRAINTS**
w-inintervalset(aux3, [1,1,5,5])
**VARIABLES**
**SEARCH**
PRINT[[x_00002]]
VARORDER STATIC [x_00002]
**CONSTRAINTS**
watchelement_one([1, 2], x_00002, aux0)
watchelement_one([1, 3], x_00002, aux1)
watchelement_one([1, 4], x_00002, aux2)
watchelement_one([1, 5], x_00002, aux3)
ineq(x_00002, aux0, 0)
ineq(x_00002, aux1, 0)
ineq(x_00002, aux2, 0)
ineq(x_00002, aux3, 0)
**EOF**
