{
  "name": "conjure-oxide-vscode",
  "displayName": "Conjure Oxide VSCode",
  "description": "Conjure Oxide's LSP support for Essence",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/conjure-cp/conjure-oxide/tree/main/tools/vscode-ext"
  },
  "categories": [
    "Programming Languages"
  ],
  "engines": {
    "vscode": "^1.22.0"
  },
  "main": "./tools/vscode-ext/out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "essence",
        "aliases": [
          "essence",
          "Essence"
        ],
        "extensions": [
          ".essence",
          ".params",
          ".solution"
        ],
        "configuration": "./tools/vscode-ext/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "essence",
        "scopeName": "source.essence",
        "path": "tools/vscode-ext/syntaxes/essence.tmLanguage.json"
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "letting",
        "description": "An Essence letting bind",
        "superType": "variable"
      },
      {
        "id": "find",
        "description": "An Essence decision variable",
        "superType": "variable"
      },
      {
        "id": "domain",
        "description": "An Essence domain",
        "superType": "type"
      }
    ],
    "semanticTokenScopes": [{
      "scopes": {
        "number": ["constant.numeric"],
        "function": ["entity.name.function"],
        "variable": ["variable.other"],
        "letting": ["variable.other.letting"],
        "find": ["variable.other.find"],
        "domain": ["entity.name.type.domain"]
      }
    }]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "lint": "eslint ./client/src --ext .ts,.tsx",
    "postinstall": "cd client && npm install && cd .."
  },
  "devDependencies": {
    "@types/node": "^18.14.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "emscripten": "^0.0.2-beta",
    "tree-sitter-cli": "^0.26.7"
  }
}
