language ESSENCE' 1.0

given fin1: int
given fin2: int
given fin3: int
given fin4: int
given fin5: int
given fin6: int
given dataset_ExplicitBoundedR6_Length: int(fin1)
given dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy:
        matrix indexed by [int(1..fin1), int(1..fin2)] of int(fin3..fin4 + 1)
given dataset_ExplicitBoundedR6_Values_2: matrix indexed by [int(1..fin1)] of int(fin5..fin6)
letting n be
        max([dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q25, q26]
                 | q25 : int(1..fin1), q26 : int(1..fin2), q25 <= fin1,
                   dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q25, q26] != fin4 + 1])
letting nbObservations be fin1
find omitList_ExplicitBounded_Length: int(nbObservations)
find omitList_ExplicitBounded_Values: matrix indexed by [int(1..nbObservations)] of bool
find rel1_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
find survivor1_ExplicitBoundedR2_Length: int(nbObservations)
find survivor1_ExplicitBoundedR2_Values_Occurrence: matrix indexed by [int(1..nbObservations), int(1..n)] of bool
find rel2_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
find survivor2_ExplicitBoundedR2_Length: int(nbObservations)
find survivor2_ExplicitBoundedR2_Values_Occurrence: matrix indexed by [int(1..nbObservations), int(1..n)] of bool
find score: int(0..nbObservations)
such that
    and([and([and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, q18] ->
                   or([dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q20] = q18
                           | q20 : int(1..fin2),
                             dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q20] != fin4 + 1])
                       | q18 : int(1..n)]),
              row <= nbObservations, row <= fin1;
                  int(1..3)])
         /\
         (omitList_ExplicitBounded_Values[row] /\
          !and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, dataset_ExplicitBoundedR6_Values_2[row]],
                row <= fin1, row <= nbObservations;
                    int(1..3)])
          /\ row <= nbObservations
          \/
          !omitList_ExplicitBounded_Values[row] /\ row <= nbObservations /\
          and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, dataset_ExplicitBoundedR6_Values_2[row]], row <= fin1,
               row <= nbObservations;
                   int(1..3)]))
         /\
         and([survivor1_ExplicitBoundedR2_Values_Occurrence
                  [row, dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q22]]
              /\ row <= nbObservations
              <->
              and([!rel1_RelationAsMatrix
                        [dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q21],
                         dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q22]]
                       | q21 : int(1..fin2),
                         dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q21] != fin4 + 1,
                         row <= fin1])
                  | q22 : int(1..fin2),
                    dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[row, q22] != fin4 + 1, row <= fin1])
             | row : int(1..nbObservations)]),
    and([and([and([survivor2_ExplicitBoundedR2_Values_Occurrence[row, q23] ->
                   survivor1_ExplicitBoundedR2_Values_Occurrence[row, q23]
                       | q23 : int(1..n)]),
              row <= nbObservations, row <= nbObservations;
                  int(1..3)])
         /\
         (omitList_ExplicitBounded_Values[row] /\
          !and([survivor2_ExplicitBoundedR2_Values_Occurrence[row, dataset_ExplicitBoundedR6_Values_2[row]],
                row <= fin1, row <= nbObservations;
                    int(1..3)])
          /\ row <= nbObservations
          \/
          !omitList_ExplicitBounded_Values[row] /\ row <= nbObservations /\
          and([survivor2_ExplicitBoundedR2_Values_Occurrence[row, dataset_ExplicitBoundedR6_Values_2[row]], row <= fin1,
               row <= nbObservations;
                   int(1..3)]))
         /\
         and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, q2] ->
              (survivor2_ExplicitBoundedR2_Values_Occurrence[row, q2] /\ row <= nbObservations <->
               and([survivor1_ExplicitBoundedR2_Values_Occurrence[row, y] -> !rel2_RelationAsMatrix[y, q2]
                        | y : int(1..n), row <= nbObservations]))
                  | q2 : int(1..n), row <= nbObservations])
             | row : int(1..nbObservations)]),
    score = sum([toInt(omitList_ExplicitBounded_Values[row]) | row : int(1..nbObservations)]),
    and([row <= nbObservations | row : int(1..nbObservations)]),
    1 <= sum([sum([toInt(rel1_RelationAsMatrix[q9, q10]) | q10 : int(1..n)]) | q9 : int(1..n)]),
    and([!rel1_RelationAsMatrix[q6, q6] | q6 : int(1..n)]),
    and([rel1_RelationAsMatrix[q6, q7] /\ rel1_RelationAsMatrix[q7, q8] -> rel1_RelationAsMatrix[q6, q8]
             | q6 : int(1..n), q7 : int(1..n), q8 : int(1..n)]),
    1 <= sum([sum([toInt(rel2_RelationAsMatrix[q16, q17]) | q17 : int(1..n)]) | q16 : int(1..n)]),
    and([!rel2_RelationAsMatrix[q13, q13] | q13 : int(1..n)]),
    and([rel2_RelationAsMatrix[q13, q14] /\ rel2_RelationAsMatrix[q14, q15] -> rel2_RelationAsMatrix[q13, q15]
             | q13 : int(1..n), q14 : int(1..n), q15 : int(1..n)])

