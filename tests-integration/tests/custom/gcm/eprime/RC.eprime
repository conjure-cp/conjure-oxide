language ESSENCE' 1.0

given fin1: int
given fin2: int
given fin3: int
given fin4: int
given fin5: int
given fin6: int
given dataset_ExplicitBoundedR6_Length: int(fin1)
given dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy:
        matrix indexed by [int(1..fin1), int(1..fin2)] of int(fin3..fin4 + 1)
given dataset_ExplicitBoundedR6_Values_2: matrix indexed by [int(1..fin1)] of int(fin5..fin6)
letting n be
        max([dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q11, q12]
                 | q11 : int(1..fin1), q12 : int(1..fin2), q11 <= fin1,
                   dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q11, q12] != fin4 + 1])
letting nbObservations be fin1
find score: int(0..nbObservations)
find rel_RelationAsMatrix: matrix indexed by [int(1..n), int(1..n)] of bool
such that
    nbObservations - score =
    sum([toInt(and([rel_RelationAsMatrix
                        [dataset_ExplicitBoundedR6_Values_2[q8],
                         dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q8, q9]]
                        | q9 : int(1..fin2),
                          dataset_ExplicitBoundedR6_Values_1_ExplicitVarSizeWithDummy[q8, q9] != fin4 + 1]))
             | q8 : int(1..fin1), q8 <= fin1]),
    and([rel_RelationAsMatrix[q2, q3] \/ rel_RelationAsMatrix[q3, q2] | q2 : int(1..n), q3 : int(1..n)]),
    and([rel_RelationAsMatrix[q2, q2] | q2 : int(1..n)]),
    and([rel_RelationAsMatrix[q2, q3] /\ rel_RelationAsMatrix[q3, q2] -> q2 = q3 | q2 : int(1..n), q3 : int(1..n)]),
    and([rel_RelationAsMatrix[q2, q3] /\ rel_RelationAsMatrix[q3, q4] -> rel_RelationAsMatrix[q2, q4]
             | q2 : int(1..n), q3 : int(1..n), q4 : int(1..n)])

dominance relation
    score < fromSolution(score)

