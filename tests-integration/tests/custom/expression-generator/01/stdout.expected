}find a: set  of int(1..4)
find b: set  of int(6..7)
find x: set  of int(1..10)

such that

([ i | i <- x ] = Matrix([Int(1), Int(2), Int(3), Int(4), Int(5), Int(6), Int(7), Int(8), Int(9), Int(10)], Moo { inner: Int([UnboundedR(1)]) })),
(sum([ i | i <- (a union b), j <- b ]) = 2)

