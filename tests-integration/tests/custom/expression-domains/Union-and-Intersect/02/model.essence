find x : set (maxSize 1) of int(1..2)
find y : set (maxSize 1) of int(3..4)
find a : set (maxSize 2) of int(1..3)
find b : set (maxSize 2) of int(1..2)
such that x union y subsetEq a intersect b

$ initial domains
$ ((x union y) subsetEq (a intersect b)) :: bool
$ (x union y) :: set (maxSize 2) of int(1..4)
$  x :: set (maxSize 1) of int(1..2)
$  y :: set (maxSize 1) of int(3..4)
$ (a intersect b) :: set (maxSize 2) of int(1..2)
$  a :: set (maxSize 2) of int(1..3)
$  b :: set (maxSize 2) of int(1..2)

$ pruned domains
$ ((x union y) subsetEq (a intersect b)) :: bool
$ (x union y) :: set (maxSize 1) of int(1..2)
$  x :: set (maxSize 1) of int(1..2)
$  y :: set (maxSize 0) of int(3..4)
$ (a intersect b) :: set (maxSize 2) of int(1..2)
$  a :: set (maxSize 2) of int(1..3)
$  b :: set (maxSize 2) of int(1..2)
