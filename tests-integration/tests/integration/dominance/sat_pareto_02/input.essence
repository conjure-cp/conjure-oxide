find x : bool
find y : bool
find z : bool

such that
    x \/ y \/ z

dominanceRelation (
    (x -> fromSolution(x)) /\
    (y -> fromSolution(y)) /\
    (z -> fromSolution(z)) /\
    (
        ((!x) /\ fromSolution(x)) \/
        ((!y) /\ fromSolution(y)) \/
        ((!z) /\ fromSolution(z))
    )
)
