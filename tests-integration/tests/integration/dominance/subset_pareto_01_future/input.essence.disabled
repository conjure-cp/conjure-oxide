letting n be 4
letting cost be [3, 2, 4, 6]
letting carbon be [1, 4, 2, 5]

find selected : matrix indexed by [int(1..n)] of bool

such that
    sum([ toInt(selected[i]) | i : int(1..n) ]) = 1

find total_cost : int(0..20)
such that
    total_cost = sum([ cost[i] | i : int(1..n), selected[i] ])

find total_carbon : int(0..20)
such that
    total_carbon = sum([ carbon[i] | i : int(1..n), selected[i] ])

dominance relation
    (total_cost <= fromSolution(total_cost)) /\
    (total_carbon <= fromSolution(total_carbon)) /\
    (
        (total_cost < fromSolution(total_cost)) \/
        (total_carbon < fromSolution(total_carbon))
    )
